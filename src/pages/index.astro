---
// index.astro — galvenā lapa ar Carbon React komponentēm
import Layout from "../components/astro/Layout.astro";
import DashboardApp from "../components/react/DashboardApp";
---

<Layout title="A11y Headings">
  <DashboardApp client:load />
</Layout>

<style is:global>
  /* ===== Base Reset ===== */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html, body {
    overflow-x: hidden;
    width: 100%;
  }

  /* ===== Main Layout ===== */
  .check-page-layout {
    display: flex;
    min-height: calc(100vh - 48px);
    width: 100%;
    overflow-x: hidden;
  }

  /* ===== Overlay ===== */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 48px 0 0 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 150;
  }

  .sidebar-overlay.visible {
    display: block;
  }

  /* ===== Sidebar ===== */
  .history-sidebar {
    width: 280px;
    min-width: 280px;
    flex-shrink: 0;
    background: #fff;
    border-right: 1px solid #e0e0e0;
    padding: 1rem;
    overflow-y: auto;
    height: calc(100vh - 48px);
    position: sticky;
    top: 48px;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .sidebar-header h2 {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0;
  }

  .close-sidebar-btn {
    display: none;
  }

  .history-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .history-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.625rem 0.75rem;
    width: 100%;
    background: #f4f4f4;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    text-align: left;
    font: inherit;
  }

  .history-item:hover {
    background: #e8e8e8;
  }

  .history-item.active {
    background: #c6c6c6;
  }

  .status-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .status-pass { color: #198038; }
  .status-fail { color: #da1e28; }

  .item-content {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .item-title {
    font-size: 0.875rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .item-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: #8d8d8d;
  }

  /* ===== Main Content ===== */
  .check-main {
    flex: 1;
    min-width: 0;
    max-width: 100%;
    padding: 1.5rem;
    overflow: hidden;
  }

  .loading-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }

  /* ===== Check Detail ===== */
  .check-detail {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 900px;
    overflow: hidden;
  }

  .check-detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .check-detail-info {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .check-detail-info h1 {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    word-break: break-word;
  }

  .check-url {
    font-size: 0.875rem;
    word-break: break-all;
  }

  .check-meta {
    font-size: 0.875rem;
    color: #525252;
    margin-top: 0.25rem;
  }

  .check-detail-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .share-url-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: #f4f4f4;
    border-radius: 4px;
    flex-wrap: wrap;
    width: 100%;
    overflow: hidden;
  }

  .share-url-link {
    flex: 1;
    min-width: 0;
    font-size: 0.875rem;
    word-break: break-all;
    color: #0f62fe;
  }

  .share-url-link:hover {
    text-decoration: underline;
  }

  .share-url-copy {
    flex-shrink: 0;
  }

  .copied-tag {
    flex-shrink: 0;
  }

  .compliance-badge {
    display: inline-flex !important;
    align-items: center !important;
    gap: 0.5rem;
  }

  .compliance-badge svg {
    vertical-align: middle;
    flex-shrink: 0;
  }

  .summary-box {
    background: #f4f4f4;
    padding: 1rem;
    border-radius: 4px;
    line-height: 1.5;
    word-break: break-word;
  }

  .check-detail h2 {
    font-size: 1.125rem;
    margin: 0;
  }

  .check-item-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .no-issues {
    color: #525252;
    margin: 0;
  }

  /* ===== Findings Cards ===== */
  .findings-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .finding-card {
    background: #f4f4f4;
    border-radius: 4px;
    border-left: 3px solid #da1e28;
    padding: 0.75rem 1rem;
  }

  .finding-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .finding-element {
    font-weight: 600;
    font-size: 0.875rem;
  }

  .finding-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-left: 1.5rem;
  }

  .finding-row {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .finding-label {
    color: #525252;
    flex-shrink: 0;
  }

  .finding-value {
    word-break: break-word;
  }

  .finding-expected {
    color: #198038;
  }

  /* ===== Outline Section - Responsive Fix ===== */
  .outline-section {
    margin-top: 1rem;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  .outline-comparison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1rem;
    width: 100%;
    max-width: 100%;
  }

  .outline-col {
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
  }

  .outline-col h3 {
    font-size: 0.875rem;
    color: #525252;
    margin: 0 0 0.5rem;
    font-weight: 500;
  }

  /* Fix Carbon CodeSnippet width - CRITICAL */
  .outline-code,
  .outline-code.cds--snippet,
  .outline-code.cds--snippet--multi {
    max-width: 100% !important;
    width: 100% !important;
  }

  .outline-code .cds--snippet-container,
  .cds--snippet-container {
    max-width: 100% !important;
  }

  .outline-code pre,
  .cds--snippet--multi pre {
    white-space: pre-wrap !important;
    word-break: break-word !important;
    overflow-wrap: break-word !important;
  }

  .outline-current .cds--snippet--multi {
    background: #fff8e6;
    border: 1px solid #f1c21b;
  }

  .outline-suggested .cds--snippet--multi,
  .outline-good.cds--snippet--multi {
    background: #e8f4e8;
    border: 1px solid #198038;
  }

  .outline-success {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  .outline-success .cds--tag {
    display: inline-flex !important;
    align-items: center !important;
    gap: 0.25rem;
  }

  .outline-success .cds--tag svg {
    vertical-align: middle;
    flex-shrink: 0;
  }

  /* ===== Accordion Fix ===== */
  .cds--accordion__content {
    overflow-x: auto;
  }

  /* ===== Welcome Screen ===== */
  .welcome-screen {
    padding: 1.5rem;
  }

  .welcome-screen h1 {
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
  }

  .welcome-instruction {
    color: #525252;
    margin: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .stat-card {
    text-align: center;
    padding: 1.5rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 600;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #525252;
    margin-top: 0.25rem;
  }

  .reset-info {
    color: #525252;
    margin-top: 1.5rem;
    font-size: 0.875rem;
  }

  /* ===== RESPONSIVE: Tablet (1024px) ===== */
  @media (max-width: 1024px) {
    .history-sidebar {
      width: 220px;
      min-width: 220px;
    }

    .check-main {
      padding: 1rem;
    }

    .outline-comparison {
      gap: 0.75rem;
    }
  }

  /* ===== RESPONSIVE: Small Tablet (768px) ===== */
  @media (max-width: 768px) {
    .check-page-layout {
      display: block;
    }

    .history-sidebar {
      position: fixed;
      top: 48px;
      left: 0;
      bottom: 0;
      width: 85vw;
      max-width: 300px;
      min-width: auto;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      z-index: 200;
      box-shadow: none;
    }

    .history-sidebar.open {
      transform: translateX(0);
      box-shadow: 4px 0 16px rgba(0, 0, 0, 0.15);
    }

    .close-sidebar-btn {
      display: flex;
    }

    .check-main {
      width: 100%;
      max-width: 100%;
      padding: 1rem;
    }

    .check-detail {
      max-width: 100%;
    }

    .check-detail-header {
      flex-direction: column;
    }

    .check-detail-actions {
      width: 100%;
    }

    /* Stack outline comparison vertically */
    .outline-comparison {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }

  }

  /* ===== RESPONSIVE: Mobile (480px) ===== */
  @media (max-width: 480px) {
    .history-sidebar {
      width: 100%;
      max-width: 100%;
    }

    .check-main {
      padding: 0.75rem;
    }

    .check-detail {
      gap: 1rem;
    }

    .check-detail-info h1 {
      font-size: 1.125rem;
    }

    .check-detail-actions {
      flex-direction: column;
    }

    .check-detail-actions .cds--btn {
      width: 100%;
      justify-content: center;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }

    .stat-card {
      display: flex;
      justify-content: space-between;
      align-items: center;
      text-align: left;
      padding: 1rem;
    }

    .stat-value {
      font-size: 1.5rem;
    }

    .welcome-screen {
      padding: 1rem;
    }

    .welcome-screen h1 {
      font-size: 1.25rem;
    }

    /* Table compact on mobile */
    .findings-table {
      font-size: 0.75rem;
    }

    .findings-table th,
    .findings-table td {
      padding: 0.375rem 0.5rem;
    }

    .share-url-container {
      flex-direction: column;
      align-items: stretch;
    }
  }

  /* ===== RESPONSIVE: Small Mobile (360px) ===== */
  @media (max-width: 360px) {
    .check-main {
      padding: 0.5rem;
    }

    .check-detail-info h1 {
      font-size: 1rem;
    }

    .stat-card {
      padding: 0.75rem;
    }

    .stat-value {
      font-size: 1.25rem;
    }
  }
</style>
